{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug API",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "job_agent_api.main:app",
        "--app-dir",
        "services/api/src",
        "--reload",
        "--reload-dir",
        "services/api/src",
        "--host",
        "0.0.0.0",
        "--port",
        "8000"
      ],
      "cwd": "${workspaceFolder}",
      "justMyCode": true
    },
    {
      "name": "Debug Web",
      "type": "node-terminal",
      "request": "launch",
      "command": "pnpm dev:web",
      "cwd": "${workspaceFolder}"
    }
  ],
  "compounds": [
    {
      "name": "Debug Web + API",
      "configurations": ["Debug API", "Debug Web"]
    }
  ]
}
